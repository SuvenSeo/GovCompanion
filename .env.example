# Provider fallback chain (comma-separated). Tries each until one works.
# Default: groq,openrouter,nvidia,anthropic (only providers with keys are used)
AI_PROVIDER_CHAIN=groq,openrouter,nvidia,anthropic

# Legacy single provider (optional)
AI_PROVIDER=groq

# Groq — fast, great for live demos (default: llama-3.3-70b-versatile)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# OpenRouter — strong multilingual / structured output
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash
OPENROUTER_USE_FREE=false
OPENROUTER_SITE_URL=https://govcompanion-lk.vercel.app

# NVIDIA NIM — fallback when Groq/OpenRouter hit rate limits
# Get a key at https://build.nvidia.com — enable each model in your catalog first
NVIDIA_NIM_API_KEY=
# Primary: instruction-following for documents, fees, office locations
NVIDIA_NIM_MODEL=meta/llama-3.3-70b-instruct
# Fallbacks (comma-separated): reasoning + lighter model if primary is busy
NVIDIA_NIM_FALLBACK_MODELS=nvidia/llama-3.3-nemotron-super-49b-v1.5,nvidia/nemotron-3-nano-30b-a3b
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1

# Optional Anthropic direct
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Per-user rate limits (IP + browser session). Protects your API quota.
RATE_LIMIT_PER_MINUTE=5
RATE_LIMIT_PER_HOUR=25
