# Primary provider: groq | openrouter | anthropic (auto-detects if unset)
AI_PROVIDER=groq

# Groq — fast, great for live demos (default: llama-3.3-70b-versatile)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# OpenRouter — strong multilingual / structured output (default: google/gemini-2.0-flash-001)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash
OPENROUTER_SITE_URL=https://gov-navigator-lk.vercel.app

# Optional Anthropic direct
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
